# Polymarket execution-engine local environment example.
# Copy to a local, untracked .env before use. Never commit real secrets.

# HTTP bind address for pmx-api.
PMX_API_BIND_ADDR=127.0.0.1:8080

# Runtime profile label used by pmx-api fail-closed checks.
# `production` forbids PMX_API_STORAGE=in_memory_scaffold.
PMX_API_PROFILE=local

# Store backend for pmx-api: `postgres` or `in_memory_scaffold`.
PMX_API_STORAGE=postgres

# Apply bundled PostgreSQL schema at pmx-api startup when set to 1/true/yes.
# Keep 0 when migrations are managed externally.
PMX_API_APPLY_SCHEMA=0

# PostgreSQL URL for pmx-api. DATABASE_URL is accepted as fallback by pmx-api.
PMX_DATABASE_URL=postgres://pmx:pmx@localhost:5432/pmx

# PostgreSQL URL used by Rust PostgreSQL tests and validation drills.
PMX_TEST_DATABASE_URL=postgres://pmx:pmx@localhost:5432/pmx_test

# Bearer token for service/query API routes.
PM_EXEC_SERVICE_TOKEN=REPLACE_WITH_SERVICE_BEARER_TOKEN

# Bearer token for admin API routes. Must be distinct from service token.
PM_EXEC_ADMIN_TOKEN=REPLACE_WITH_DISTINCT_ADMIN_BEARER_TOKEN

# Gateway mode for local execution experiments: `fake` unless explicitly testing SDK paths.
PMX_GATEWAY_MODE=fake

# Runtime observation freshness window in seconds for runtime-state reads.
PMX_RUNTIME_OBSERVATION_TTL_SECONDS=120

# Optional SDK authenticated non-trading smoke. Keep disabled by default.
PMX_RUN_AUTHENTICATED_NON_TRADING_SMOKE=0

# Optional SDK sign-only construction dry run. Requires explicit allow flag and signer material.
PMX_RUN_SIGN_ONLY_DRY_RUN=0

# Explicit allow gate for SDK sign-only construction dry run.
PMX_ALLOW_SIGN_ONLY_DRY_RUN=0

# Live submit environment gate. Keep disabled unless a reviewed release decision says otherwise.
PMX_ALLOW_LIVE_SUBMIT=0

# Live cancel environment gate. Keep disabled unless a reviewed release decision says otherwise.
PMX_ALLOW_LIVE_CANCEL=0

# Real-funds canary environment gate. Keep disabled unless a reviewed release decision says otherwise.
PMX_ALLOW_REAL_FUNDS_CANARY=0

# SDK call timeout in seconds for adapter smoke/canary paths.
PMX_SDK_CALL_TIMEOUT_SECS=10

# Official SDK signer material. Leave unset in normal development.
# POLYMARKET_PRIVATE_KEY=REPLACE_WITH_EXTERNAL_SECRET_REFERENCE_ONLY
# POLY_API_KEY=REPLACE_WITH_L2_API_KEY_UUID
# POLY_API_SECRET=REPLACE_WITH_L2_API_SECRET
# POLY_API_PASSPHRASE=REPLACE_WITH_L2_API_PASSPHRASE
# PMX_CLOB_FUNDER=REPLACE_WITH_FUNDER_ADDRESS
# PMX_CLOB_SIGNATURE_TYPE=EOA
