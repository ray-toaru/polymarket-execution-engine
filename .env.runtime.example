# Runtime-facing identity env generated from one selected local account profile.
# This file carries only active identity and profile binding metadata.

# Active local account profile label selected from the private source inventory.
PMX_ACTIVE_ACCOUNT_PROFILE=REPLACE_WITH_PROFILE_LABEL

# Active local account id bound to the selected profile.
PMX_ACTIVE_ACCOUNT_ID=REPLACE_WITH_ACCOUNT_ID

# Local non-secret profile reference bound to the selected profile.
PMX_ACTIVE_PROFILE_REF=local-profile://REPLACE_WITH_PROFILE_LABEL
