      "type": "string",
      "minLength": 1
    },
    "archived_manifest_sha256": {
      "type": "string",
      "minLength": 1
    },
    "github_evidence_details": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root_ci",
        "hermes_ci",
        "execution_engine_ci",
        "credentialed_sdk"
      ],
      "properties": {
        "root_ci": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "run_id",
            "workflow_name",
            "workflow_run_url",
            "commit_sha",
            "status",
            "timestamp"
          ],
          "properties": {
            "run_id": {
              "type": "string",
              "minLength": 1
            },
            "workflow_name": {
              "type": "string",
              "minLength": 1
            },
            "workflow_run_url": {
              "type": "string",
              "minLength": 1
            },
            "commit_sha": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{7,64}$"
            },
            "status": {
              "enum": [
                "success",
                "local_passed",
                "not_applicable_non_live"
              ]
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "hermes_ci": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "run_id",
            "workflow_name",
            "workflow_run_url",
            "commit_sha",
            "status",
            "timestamp"
          ],
          "properties": {
            "run_id": {
              "type": "string",
              "minLength": 1
            },
            "workflow_name": {
              "type": "string",
              "minLength": 1
            },
            "workflow_run_url": {
              "type": "string",
              "minLength": 1
            },
            "commit_sha": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{7,64}$"
            },
            "status": {
              "enum": [
                "success",
                "local_passed",
                "not_applicable_non_live"
              ]
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "execution_engine_ci": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "run_id",
            "workflow_name",
            "workflow_run_url",
            "commit_sha",
            "status",
            "timestamp"
          ],
          "properties": {
            "run_id": {
              "type": "string",
              "minLength": 1
            },
            "workflow_name": {
              "type": "string",
              "minLength": 1
            },
            "workflow_run_url": {
              "type": "string",
              "minLength": 1
            },
            "commit_sha": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{7,64}$"
            },
            "status": {
              "enum": [
                "success",
                "local_passed",
                "not_applicable_non_live"
              ]
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "credentialed_sdk": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "run_id",
            "workflow_name",
            "workflow_run_url",
            "commit_sha",
            "status",
            "timestamp"
          ],
          "properties": {
            "run_id": {
              "type": "string",
              "minLength": 1
            },
            "workflow_name": {
              "type": "string",
              "minLength": 1
            },
            "workflow_run_url": {
              "type": "string",
              "minLength": 1
            },
            "commit_sha": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{7,64}$"
            },
            "status": {
              "enum": [
                "success",
                "local_passed",
                "not_applicable_non_live"
              ]
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    },
    "reviewer_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "review_signature_evidence_ref": {
      "type": "string",
      "minLength": 1
    },
    "review_signature_evidence_sha256": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_check_evidence_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_hash_reviewed",
        "evidence_manifest_hash_reviewed",
        "market_candidate_reviewed",
        "runtime_truth_reviewed",
        "risk_limits_reviewed",
        "secret_custody_reviewed",
        "alerting_reviewed",
        "rollback_reviewed",
        "reconcile_and_cancel_fallback_reviewed"
      ],
