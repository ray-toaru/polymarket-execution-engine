          "type": "string",
          "minLength": 1
        },
        "evidence_manifest_hash_reviewed": {
          "type": "string",
          "minLength": 1
        },
        "market_candidate_reviewed": {
          "type": "string",
          "minLength": 1
        },
        "runtime_truth_reviewed": {
          "type": "string",
          "minLength": 1
        },
        "risk_limits_reviewed": {
          "type": "string",
          "minLength": 1
        },
        "secret_custody_reviewed": {
          "type": "string",
          "minLength": 1
        },
        "alerting_reviewed": {
          "type": "string",
          "minLength": 1
        },
        "rollback_reviewed": {
          "type": "string",
          "minLength": 1
        },
        "reconcile_and_cancel_fallback_reviewed": {
          "type": "string",
