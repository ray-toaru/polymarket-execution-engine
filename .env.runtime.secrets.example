# Runtime-facing secret env generated from one selected local account profile.
# Keep this file local. It contains private key and API credentials.

# Generic runtime L1 private key for the active account.
POLYMARKET_PRIVATE_KEY=REPLACE_WITH_PRIVATE_KEY

# Generic runtime L2 API key for the active account.
POLY_API_KEY=REPLACE_WITH_L2_API_KEY_UUID

# Generic runtime L2 API secret for the active account.
POLY_API_SECRET=REPLACE_WITH_L2_API_SECRET

# Generic runtime L2 API passphrase for the active account.
POLY_API_PASSPHRASE=REPLACE_WITH_L2_API_PASSPHRASE

# Generic runtime signature type for the active account.
PMX_CLOB_SIGNATURE_TYPE=POLY_1271

# Generic runtime CLOB funder for deposit-wallet / Poly1271 auth.
PMX_CLOB_FUNDER=REPLACE_WITH_FUNDER_ADDRESS
