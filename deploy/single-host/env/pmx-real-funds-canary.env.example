# Single-host real-funds canary environment example.
# Copy outside the repository before use. Keep real secret values out of this file.

# Human-readable profile label for the canary unit.
PMX_PROFILE=single-host-limited-canary-dry-run

# Reference to local secret custody provider, not the secret value itself.
PMX_SECRET_CUSTODY_REF=pass://polymarket-execution-engine/controlled-canary

# Operator-reviewed approval file.
PMX_CANARY_APPROVAL_FILE=/etc/pmx/canary/approval.json

# Operator-reviewed release decision file.
PMX_CANARY_RELEASE_DECISION_FILE=/etc/pmx/canary/release-decision.json

# Operator-reviewed candidate market file.
PMX_CANARY_MARKET_FILE=/etc/pmx/canary/candidate-market.json

# Runtime truth file for dry-run packages.
PMX_CANARY_RUNTIME_TRUTH_FILE=/etc/pmx/canary/runtime-truth.json

# Runtime truth store. Use postgres for durable runtime truth.
PMX_CANARY_RUNTIME_TRUTH_STORE=postgres

# Name of the environment variable containing the runtime truth PostgreSQL URL.
PMX_CANARY_RUNTIME_TRUTH_DATABASE_URL_ENV=PMX_DATABASE_URL

# Condition id used to scope market runtime truth.
PMX_CANARY_RUNTIME_TRUTH_CONDITION_ID=REPLACE_WITH_CONDITION_ID

# SHA-256 of the reviewed release zip artifact.
PMX_CANARY_ARTIFACT_SHA256=REPLACE_WITH_RELEASE_ZIP_SHA256

# SHA-256 of the reviewed current evidence manifest.
PMX_CANARY_EVIDENCE_MANIFEST_SHA256=REPLACE_WITH_EVIDENCE_MANIFEST_SHA256

# Operator-approved account id for this canary.
PMX_CANARY_ACCOUNT_ID=REPLACE_WITH_OPERATOR_APPROVED_ACCOUNT

# Server-side execution id for this canary.
PMX_CANARY_EXECUTION_ID=REPLACE_WITH_EXECUTION_ID

# Server-side plan hash for this canary.
PMX_CANARY_PLAN_HASH=REPLACE_WITH_PLAN_HASH

# Idempotency key reserved for this canary.
PMX_CANARY_IDEMPOTENCY_KEY=REPLACE_WITH_IDEMPOTENCY_KEY

# Daily notional already used before this canary attempt.
PMX_CANARY_DAILY_USED_NOTIONAL_USD=0

# Durable approval-consumed marker written before an armed remote call.
PMX_CANARY_APPROVAL_CONSUMED_MARKER=/var/lib/pmx/canary/approval-consumed.json

# Durable stage/final report file written during an armed canary attempt.
PMX_CANARY_REPORT_FILE=/var/lib/pmx/canary/canary-report.json

# Live submit service-level gate. Keep disabled for dry-run/preflight packages.
PMX_LIVE_SUBMIT_ENABLED=0

# Live cancel service-level gate. Keep disabled for dry-run/preflight packages.
PMX_LIVE_CANCEL_ENABLED=0

# Production deployment gate. Keep disabled for dry-run/preflight packages.
PMX_PRODUCTION_DEPLOYMENT_ENABLED=0

# Adapter/live submit environment gate. Keep disabled until reviewed.
PMX_ALLOW_LIVE_SUBMIT=0

# Adapter/live cancel environment gate. Keep disabled until reviewed.
PMX_ALLOW_LIVE_CANCEL=0

# Real-funds canary environment gate. Keep disabled until reviewed.
PMX_ALLOW_REAL_FUNDS_CANARY=0

# Runtime worker health precondition.
PMX_RUNTIME_WORKER_HEALTHY=0

# Reconciliation worker health precondition.
PMX_RECONCILE_WORKER_HEALTHY=0

# Cancel-only fallback readiness precondition.
PMX_CANCEL_ONLY_FALLBACK_READY=0

# Kill-switch open precondition.
PMX_KILL_SWITCH_OPEN=0

# Balance and allowance check precondition.
PMX_BALANCE_ALLOWANCE_CHECKED=0

# Repository reservation existence precondition.
PMX_REPOSITORY_RESERVATION_EXISTS=0

# Idempotency key write precondition.
PMX_IDEMPOTENCY_KEY_WRITTEN=0

# Geoblock allow precondition.
PMX_GEOBLOCK_ALLOWED=0

# Official SDK signer material. Prefer external secret injection at runtime.
# POLYMARKET_PRIVATE_KEY=REPLACE_WITH_EXTERNAL_SECRET_REFERENCE_ONLY
# POLY_API_KEY=REPLACE_WITH_L2_API_KEY_UUID
# POLY_API_SECRET=REPLACE_WITH_L2_API_SECRET
# POLY_API_PASSPHRASE=REPLACE_WITH_L2_API_PASSPHRASE
# PMX_CLOB_FUNDER=REPLACE_WITH_FUNDER_ADDRESS
# PMX_CLOB_SIGNATURE_TYPE=POLY_1271
