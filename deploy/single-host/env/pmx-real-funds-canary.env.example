# Single-host real-funds canary dry-run environment example.
# Copy outside the repository before use. Keep secret values out of this file.

PMX_PROFILE=single-host-limited-canary-dry-run
PMX_SECRET_CUSTODY_REF=pass://polymarket-execution-engine/controlled-canary
PMX_CANARY_APPROVAL_FILE=/etc/pmx/canary/approval.json
PMX_CANARY_RELEASE_DECISION_FILE=/etc/pmx/canary/release-decision.json
PMX_CANARY_ARTIFACT_SHA256=REPLACE_WITH_RELEASE_ZIP_SHA256
PMX_CANARY_EVIDENCE_MANIFEST_SHA256=REPLACE_WITH_EVIDENCE_MANIFEST_SHA256
PMX_CANARY_ACCOUNT_ID=REPLACE_WITH_OPERATOR_APPROVED_ACCOUNT
PMX_CANARY_EXECUTION_ID=REPLACE_WITH_EXECUTION_ID
PMX_CANARY_PLAN_HASH=REPLACE_WITH_PLAN_HASH
PMX_CANARY_IDEMPOTENCY_KEY=REPLACE_WITH_IDEMPOTENCY_KEY
PMX_CANARY_DAILY_USED_NOTIONAL_USD=0

PMX_LIVE_SUBMIT_ENABLED=0
PMX_LIVE_CANCEL_ENABLED=0
PMX_PRODUCTION_DEPLOYMENT_ENABLED=0
PMX_ALLOW_LIVE_SUBMIT=0
PMX_ALLOW_LIVE_CANCEL=0
PMX_ALLOW_REAL_FUNDS_CANARY=0

PMX_RUNTIME_WORKER_HEALTHY=0
PMX_RECONCILE_WORKER_HEALTHY=0
PMX_CANCEL_ONLY_FALLBACK_READY=0
PMX_KILL_SWITCH_OPEN=0
PMX_BALANCE_ALLOWANCE_CHECKED=0
PMX_REPOSITORY_RESERVATION_EXISTS=0
PMX_IDEMPOTENCY_KEY_WRITTEN=0
PMX_GEOBLOCK_ALLOWED=0
