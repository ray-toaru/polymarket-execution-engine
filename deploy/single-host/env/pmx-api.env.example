# Single-host pmx-api environment example.
# Copy outside the repository before use. Keep secret values out of this file.

# Human-readable deployment profile label.
PMX_PROFILE=single-host-limited

# API profile used by fail-closed runtime checks.
PMX_API_PROFILE=single-host-limited

# pmx-api listener address.
PMX_API_BIND_ADDR=127.0.0.1:8080

# API storage backend. Production-like single-host deployments must use postgres.
PMX_API_STORAGE=postgres

# Apply schema at process startup. Prefer 0 when migrations are managed separately.
PMX_API_APPLY_SCHEMA=0

# Bearer token for service/query routes.
PMX_API_SERVICE_TOKEN=REPLACE_WITH_SERVICE_BEARER_TOKEN

# Bearer token for admin routes. Must be distinct from service token.
PMX_API_ADMIN_TOKEN=REPLACE_WITH_DISTINCT_ADMIN_BEARER_TOKEN

# Reference to the actual PostgreSQL URL source. Do not put the URL here.
PMX_DATABASE_URL_REF=env://PMX_DATABASE_URL

# Reference to the configured local secret custody provider.
PMX_SECRET_CUSTODY_REF=pass://polymarket-execution-engine/controlled-canary

# Live submit service-level gate. Keep disabled for limited single-host validation.
PMX_LIVE_SUBMIT_ENABLED=0

# Live cancel service-level gate. Keep disabled for limited single-host validation.
PMX_LIVE_CANCEL_ENABLED=0

# Production deployment gate. Keep disabled for limited single-host validation.
PMX_PRODUCTION_DEPLOYMENT_ENABLED=0

# Adapter/live submit environment gate. Keep disabled until reviewed.
PMX_ALLOW_LIVE_SUBMIT=0

# Adapter/live cancel environment gate. Keep disabled until reviewed.
PMX_ALLOW_LIVE_CANCEL=0

# Real-funds canary environment gate. Keep disabled until reviewed.
PMX_ALLOW_REAL_FUNDS_CANARY=0

# Runtime worker health truth. False until a real worker writes durable truth.
PMX_RUNTIME_WORKER_HEALTHY=0

# Reconciliation worker health truth. False until a real worker writes durable truth.
PMX_RECONCILE_WORKER_HEALTHY=0

# Cancel-only fallback readiness truth. False until a real fallback is proven.
PMX_CANCEL_ONLY_FALLBACK_READY=0

# Kill-switch truth. Keep 0 unless durable runtime state proves it is open for canary.
PMX_KILL_SWITCH_OPEN=0
