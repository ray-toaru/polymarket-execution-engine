# Local private account-profile inventory example.
# Copy to a local, untracked .env.profiles before use. Do not pass this file
# directly to runtime commands; convert it into a generic runtime env with
# `python scripts/activate_pmx_profile.py`.

# Profile-scoped account id for one local profile.
PMX_PROFILE_REPLACE_WITH_PROFILE_LABEL_ACCOUNT_ID=REPLACE_WITH_ACCOUNT_ID

# Local non-secret profile reference for one local profile.
PMX_PROFILE_REPLACE_WITH_PROFILE_LABEL_PROFILE_REF=local-profile://REPLACE_WITH_PROFILE_LABEL

# Profile-scoped L1 private key for one local profile.
PMX_PROFILE_REPLACE_WITH_PROFILE_LABEL_POLYMARKET_PRIVATE_KEY=REPLACE_WITH_PRIVATE_KEY

# Profile-scoped L2 API key for one local profile.
PMX_PROFILE_REPLACE_WITH_PROFILE_LABEL_POLY_API_KEY=REPLACE_WITH_L2_API_KEY_UUID

# Profile-scoped L2 API secret for one local profile.
PMX_PROFILE_REPLACE_WITH_PROFILE_LABEL_POLY_API_SECRET=REPLACE_WITH_L2_API_SECRET

# Profile-scoped L2 API passphrase for one local profile.
PMX_PROFILE_REPLACE_WITH_PROFILE_LABEL_POLY_API_PASSPHRASE=REPLACE_WITH_L2_API_PASSPHRASE

# Profile-scoped CLOB funder for one local profile when using deposit-wallet auth.
PMX_PROFILE_REPLACE_WITH_PROFILE_LABEL_CLOB_FUNDER=REPLACE_WITH_FUNDER_ADDRESS

# Profile-scoped signature type for one local profile.
PMX_PROFILE_REPLACE_WITH_PROFILE_LABEL_CLOB_SIGNATURE_TYPE=POLY_1271
